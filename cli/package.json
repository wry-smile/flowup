{
  "name": "@wry-smile/flowup",
  "type": "module",
  "version": "3.0.0",
  "description": "CLI for scaffolding, building, and assembling Node-RED nodes and plugins with Vite",
  "author": "@wry-smile",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "Node-RED",
    "TypeScript",
    "Scaffold",
    "CLI",
    "Vite"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "main": "./dist/index.js",
  "bin": {
    "flowup": "./dist/bin/flowup.js"
  },
  "files": [
    "README.md",
    "README.zh-CN.md",
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "release": "bumpp",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "commander": "catalog:",
    "find-up": "catalog:",
    "js-yaml": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "bumpp": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
