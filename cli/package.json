{
  "name": "@wry-smile/flowup",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@10.28.2",
  "description": "Node-RED TypeScript Node Starter CLI",
  "author": "@wry-smile",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "Node-RED",
    "TypeScript",
    "Node",
    "Starter",
    "CLI",
    "Monorepo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "bin": {
    "flowup": "./dist/bin/flowup.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "release": "bumpp",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "commander": "catalog:",
    "find-up": "catalog:",
    "js-yaml": "catalog:",
    "micromatch": "catalog:",
    "vite": "catalog:",
    "vite-plugin-singlefile": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "catalog:",
    "@types/micromatch": "catalog:",
    "bumpp": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
